@model Cavex.Principal.Models.VehCatAseguradora.VehCatAseguradoraSaveDto;
@{
    ViewData["Title"] = "Nueva Compañía de Seguros";
    ViewData["HeaderEyebrow"] = "Configuración";
    ViewData["HeaderSubtitle"] = "Administra el catálogo de compañías de seguros de la plataforma.";

    ViewData["TableTitle"] = "Listado de compañías de seguros";
    ViewData["TableSubtitle"] = "Catálogo de aseguradoras registradas y sus descripciones.";
    ViewData["TableCount"] = 0;
    ViewData["TableCountLabel"] = "aseguradoras";
}

@section Head {
    <link rel="stylesheet" href="~/css/vista-vehiculos.css" asp-append-version="true" />
}

<partial name="_PageHeader" />

<div class="filter-card">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <span class="eyebrow">Formulario</span>
            <h2 class="filter-title" id="formTitle">Registrar aseguradora</h2>
            <p class="cavex-subtitle" id="formSubtitle">Ingresa el nombre y la descripción para registrar la compañía de seguros.</p>
        </div>
    </div>

    <form id="formSeguro" class="filter-form-compact" novalidate onsubmit="handleFormSubmit(event)">
        <div class="row g-3">
            <div class="col-md-12">
                <label class="form-label" for="strNombreSeguro">Nombre de la aseguradora</label>
                <input id="strNombreSeguro" name="StrValor" class="form-control no-uppercase" placeholder="Ej. GNP Seguros" required />
                <div class="invalid-feedback" id="nombreFeedback">El nombre de la aseguradora ya existe.</div>
            </div>
            <div class="col-md-12">
                <label class="form-label" for="strDescripcionSeguro">Descripción (Opcional)</label>
                <textarea id="strDescripcionSeguro" name="StrDescripcion" class="form-control no-uppercase" rows="3" placeholder="Ej. Cobertura nacional" style="resize: none;"></textarea>
                <div class="invalid-feedback" id="descripcionFeedback">La descripción contiene caracteres no válidos.</div>
            </div>
        </div>

        <div class="search-actions mt-3">
            <a class="btn btn-outline-cavex" asp-controller="Vehiculos" asp-action="Index">Volver</a>
            <button type="button" class="btn btn-outline-cavex" id="btnCancel" onclick="resetForm()" style="display: none;">Cancelar</button>
            <button type="submit" class="btn btn-cavex" id="btnSubmit">Guardar aseguradora</button>
        </div>
    </form>
</div>

<div class="cavex-card table-module">
    <partial name="_TableCardHeader" />

    <div class="table-filter-bar d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div class="table-search-box position-relative">
            <input type="text" id="tableSearch" class="form-control" placeholder="Buscar aseguradora..." oninput="handleSearch(this.value)" />
            <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle executive-table table-cavex-compact">
            <thead>
                <tr>
                    <th>Nombre de la aseguradora</th>
                    <th>Descripción</th>
                    <th class="text-end" style="width: 160px;">Acciones</th>
                </tr>
            </thead>
            <tbody id="segurosTableBody"></tbody>
        </table>
    </div>

    <div class="table-footer-bar">
        <div class="pagination-info small" id="paginationInfo">
            Mostrando 0-0 de 0 registros
        </div>
        <nav aria-label="Navegación de aseguradoras">
            <ul class="pagination pagination-cavex m-0" id="paginationList"></ul>
        </nav>
    </div>
</div>

@section Scripts {
    <script src="~/js/vehiculos/servicios-vehiculos/vista-seguros.js" asp-append-version="true"></script>
}
