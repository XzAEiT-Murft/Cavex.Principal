@model Cavex.Principal.Models.VehCatMarcaLlanta.VehCatMarcaLlantaSaveDto;
@{
    ViewBag.Title = "Nueva Marca de Llanta";
    ViewBag.HeaderEyebrow = "Configuracion";
    ViewBag.HeaderTitle = "Nueva Marca de Llanta";
    ViewBag.HeaderSubtitle = "Administra el catalogo de marcas de llantas de la plataforma.";

    ViewBag.TableTitle = "Listado de marcas de llantas";
    ViewBag.TableSubtitle = "Catalogo de marcas de llantas registradas y sus descripciones.";
    ViewBag.TableCount = 0;
    ViewBag.TableCountLabel = "marcas";
    ViewBag.TableExtraPill = "Catalogo Activo";
}

@section Head {
    <link rel="stylesheet" href="~/css/vista-marcas-llantas.css" asp-append-version="true" />
}

<partial name="_PageHeader" />

<div class="filter-card">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <span class="eyebrow">Formulario</span>
            <h2 class="filter-title" id="formTitle">Registrar marca de llanta</h2>
            <p class="cavex-subtitle" id="formSubtitle">Ingresa el nombre y la descripcion para registrar la marca de llanta.</p>
        </div>
    </div>

    <form id="formMarcaLlanta" class="filter-form-compact" novalidate onsubmit="handleFormSubmit(event)">
        <div class="row g-3">
            <div class="col-md-12">
                <label class="form-label" for="strNombreMarca">Nombre de la marca</label>
                <input id="strNombreMarca" name="StrValor" class="form-control no-uppercase" placeholder="Ej. Michelin" required />
                <div class="invalid-feedback" id="nombreFeedback">El nombre de la marca ya existe.</div>
            </div>
            <div class="col-md-12">
                <label class="form-label" for="strDescripcionMarca">Descripcion (Opcional)</label>
                <textarea id="strDescripcionMarca" name="StrDescripcion" class="form-control no-uppercase" rows="3" placeholder="Ej. Marca premium de llantas para uso comercial" style="resize: none;"></textarea>
                <div class="invalid-feedback" id="descripcionFeedback">La descripcion contiene caracteres no validos.</div>
            </div>
        </div>

        <div class="search-actions mt-3">
            <button type="submit" class="btn btn-cavex" id="btnSubmit">Guardar marca</button>
            <button type="button" class="btn btn-outline-cavex" id="btnCancel" onclick="resetForm()" style="display: none;">Cancelar</button>
        </div>
    </form>
</div>

<div class="cavex-card table-module">
    <partial name="_TableCardHeader" />

    <div class="table-filter-bar d-flex flex-wrap justify-content-end align-items-center gap-3">
        <div class="table-search-box position-relative">
            <input type="text" id="tableSearch" class="form-control" placeholder="Buscar marca..." oninput="handleSearch(this.value)" />
            <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle executive-table table-cavex-compact">
            <thead>
                <tr>
                    <th>Nombre de la marca</th>
                    <th>Descripcion</th>
                    <th class="text-end" style="width: 160px;">Acciones</th>
                </tr>
            </thead>
            <tbody id="marcasTableBody"></tbody>
        </table>
    </div>

    <div class="table-footer-bar">
        <div class="pagination-info small" id="paginationInfo">
            Mostrando 0-0 de 0 registros
        </div>
        <nav aria-label="Navegacion de marcas de llantas">
            <ul class="pagination pagination-cavex m-0" id="paginationList"></ul>
        </nav>
    </div>
</div>

@section Scripts {
    <script src="~/js/vista-marcas-llantas.js" asp-append-version="true"></script>
}
